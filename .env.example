VITE_TRANSLATION_PROVIDER=mock
VITE_TRANSLATION_API_URL=http://127.0.0.1:8788/api/translate
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
TRANSLATION_PROVIDER=mock
SUMMARY_PROVIDER=rules
REALTIME_SERVER_URL=ws://127.0.0.1:8788

# Do not put paid API keys in frontend code or commit real keys.
# Future adapters should read keys only on a trusted backend/serverless runtime.
# GPT API usage is billed separately from ChatGPT Plus.
# OPENAI_API_KEY=
# OPENAI_TRANSLATION_MODEL=gpt-4.1-mini

# Gemini API also requires its own API key and may bill usage depending on plan/limits.
# To use Gemini translation locally:
# VITE_TRANSLATION_PROVIDER=gemini
# TRANSLATION_PROVIDER=gemini
# GEMINI_API_KEY=
# GEMINI_TRANSLATION_MODEL=gemini-3.5-flash
